# Kafka cluster (Confluent Cloud)
KAFKA_BOOTSTRAP_SERVERS=<cluster>.confluent.cloud:9092
KAFKA_API_KEY=<your-kafka-api-key>
KAFKA_API_SECRET=<your-kafka-api-secret>

# Schema Registry (Confluent Cloud)
SR_URL=https://<sr-endpoint>.confluent.cloud
SR_API_KEY=<your-sr-api-key>
SR_API_SECRET=<your-sr-api-secret>

# CipherTrust Manager
CT_URL=https://<ciphertrust-host-or-ip>
CT_USERNAME=admin
CT_PASSWORD=<your-ciphertrust-password>
CT_KEK_NAME=<your-aes256-key-name>
